{
    "compilerOptions": {
        "target": "ES2023",
        "module": "Node16",
        "moduleResolution": "node16",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "strict": false,
        "types": ["node"],
        "skipLibCheck": true
    },
    "include": [
        "server.js",
        "database/**/*.js",
        "middleware/**/*.js",
        "routes/**/*.js",
        "scripts/**/*.js",
        "test/**/*.js",
        "types/**/*.d.ts"
    ],
    "exclude": ["node_modules", "coverage", "public"]
}
