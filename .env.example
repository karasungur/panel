# Runtime
NODE_ENV=development
PORT=3000

# CORS icin izin verilen origin listesi. Bos birakilirsa yalnizca same-origin/no-origin istekler calisir.
# Ornek: APP_ORIGIN=https://panel.example.com,https://www.panel.example.com
APP_ORIGIN=http://localhost:3000

# Reverse proxy arkasinda gercek IP icin sayisal hop kullanin. systemd + Nginx icin genelde 1.
TRUST_PROXY=1

# Kalici veri dizini. panel.db ve uploads burada tutulur.
# Lokal gelistirmede bos birakabilir veya ./database kullanabilirsiniz.
DATA_DIR=./database

# npm run backup icin hedef yedek dizini ve otomatik retention.
BACKUP_DIR=./database/backups
BACKUP_RETENTION_DAYS=14

# Admin giris bilgileri (seed ile olusturulur).
ADMIN_TELEFON=+905551234567
ADMIN_SIFRE=admin123

# JWT icin gizli anahtar
JWT_SECRET=cok-gizli-jwt-anahtari-degistirin

# Oturum cookie ayarlari. Panel/API farkli originlerdeyse HTTPS ile AUTH_COOKIE_SECURE=true
# ve AUTH_COOKIE_SAMESITE=none kullanin.
AUTH_COOKIE_SECURE=
AUTH_COOKIE_SAMESITE=lax
