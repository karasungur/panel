{
    "compilerOptions": {
        "target": "ES2023",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "strict": true,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "lib": ["ES2023", "DOM", "DOM.Iterable"],
        "types": [],
        "skipLibCheck": true,
        "moduleDetection": "force"
    },
    "include": ["public/assets/**/*.js", "public/assets/**/*.d.ts"],
    "exclude": ["node_modules", "coverage", "public/uploads"]
}
