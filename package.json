{
    "name": "sosyal-medya-takip-paneli",
    "version": "3.3.0",
    "description": "Teskilat Yonetim Paneli",
    "main": "server.js",
    "scripts": {
        "backup": "node scripts/backup.js",
        "check": "node scripts/check.js",
        "coverage": "node --test --experimental-test-coverage --test-coverage-lines=45 --test-coverage-branches=50 --test-coverage-functions=35 test/*.test.js",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "migrate": "node scripts/migrate.js",
        "quality": "npm run check && npm run lint && npm run format:check && npm run typecheck && npm test && npm run coverage",
        "start": "node server.js",
        "seed": "node database/seed.js",
        "test": "node --test test/*.test.js",
        "typecheck": "tsc -p tsconfig.json"
    },
    "engines": {
        "node": ">=22.13.0"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "exceljs": "^4.4.0",
        "express": "^4.19.2",
        "file-type": "^22.0.1",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.2",
        "sanitize-html": "^2.17.5",
        "zod": "^4.4.3"
    },
    "overrides": {
        "uuid": "11.1.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.19.21",
        "@types/sanitize-html": "^2.16.1",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3"
    }
}
